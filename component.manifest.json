{
  "$schema": "https://greentic-ai.github.io/greentic-component/schemas/v1/component.manifest.schema.json",
  "artifacts": {
    "component_wasm": "target/wasm32-wasip2/release/component_slot_extractor.wasm"
  },
  "capabilities": {
    "host": {
      "messaging": {
        "inbound": true,
        "outbound": true
      },
      "secrets": {
        "required": []
      },
      "telemetry": {
        "scope": "node"
      }
    },
    "wasi": {
      "clocks": true,
      "filesystem": {
        "mode": "none",
        "mounts": []
      },
      "random": false
    }
  },
  "config_schema": {
    "additionalProperties": false,
    "properties": {},
    "required": [],
    "type": "object"
  },
  "default_operation": "extract_slots",
  "describe_export": "describe",
  "hashes": {
    "component_wasm": "blake3:6adb012399168f66c08b2ee26714448599505e2c1c6e6eb98825ce0e0bd17a83"
  },
  "id": "ai.greentic.component-slot-extractor",
  "limits": {
    "memory_mb": 128,
    "wall_time_ms": 1000
  },
  "name": "component-slot-extractor",
  "operations": [
    {
      "input_schema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "properties": {
          "utterance": {
            "type": "string",
            "description": "User utterance to extract slot values from"
          },
          "slot_definitions": {
            "type": "array",
            "description": "Slot definitions to extract",
            "items": {
              "$ref": "schemas/io/input.schema.json#/$defs/SlotDefinition"
            }
          }
        },
        "required": ["utterance", "slot_definitions"],
        "title": "component-slot-extractor extract_slots input",
        "type": "object"
      },
      "name": "extract_slots",
      "output_schema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "properties": {
          "slots": {
            "type": "array",
            "description": "Extracted slot results"
          },
          "values": {
            "type": "object",
            "additionalProperties": true,
            "description": "Flat name-to-primitive map of filled slot values for adaptive-card prefill"
          },
          "filled": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Names of successfully filled slots"
          },
          "missing": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Names of required slots not filled"
          },
          "all_required_filled": {
            "type": "boolean",
            "description": "Whether all required slots are filled"
          }
        },
        "required": ["slots", "values", "filled", "missing", "all_required_filled"],
        "title": "component-slot-extractor extract_slots output",
        "type": "object"
      }
    }
  ],
  "profiles": {
    "default": "stateless",
    "supported": [
      "stateless"
    ]
  },
  "secret_requirements": [],
  "supports": [
    "messaging"
  ],
  "version": "0.1.1",
  "world": "greentic:component/component@0.6.0"
}
